@using AssetManagement.Models.Entities
@model Floor
@{
    ViewData["Title"] = $"Floor {Model.Level} — {Model.Building.Name}";
    string CritGrad(string c) => c.ToLower() switch {
        "critical" => "linear-gradient(135deg,#fa709a,#fee140)",
        "high"     => "linear-gradient(135deg,#f093fb,#f5576c)",
        "medium"   => "linear-gradient(135deg,#667eea,#764ba2)",
        "low"      => "linear-gradient(135deg,#11998e,#38ef7d)",
        _          => "linear-gradient(135deg,#a0aec0,#718096)"
    };
    string StatusColor(string s) => s.ToLower() switch {
        "operational"   => "#11998e",
        "under_maintenance" => "#f39c12",
        "decommissioned" => "#e53e3e",
        _               => "#718096"
    };
}

@section Styles {
<link rel="stylesheet" href="~/css/views/floors-details.css" asp-append-version="true" />
}

<!-- HERO -->
<div class="det-hero">
    <a asp-controller="Buildings" asp-action="Details" asp-route-id="@Model.BuildingId" class="hero-back">
        <i class="bi bi-arrow-left"></i>Back to @Model.Building.Name
    </a>
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div style="position:relative;z-index:1">
            <p class="hero-name"><i class="bi bi-layers me-2" style="opacity:.7"></i>Floor @Model.Level — @(Model.Name ?? "Unnamed")</p>
            <p class="hero-sub">@Model.Building.Name</p>
        </div>
        <div class="d-flex flex-wrap gap-2" style="position:relative;z-index:1">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="hbtn hbtn-edit">
                <i class="bi bi-pencil"></i>Edit
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mb-0"
                  onsubmit="return confirm('Delete Floor @Model.Level?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="hbtn hbtn-del"><i class="bi bi-trash"></i>Delete</button>
            </form>
        </div>
    </div>
</div>

<!-- BODY -->
<div class="row g-4">
    <div class="col-lg-4">
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="kpi-chip" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                    <i class="bi bi-cpu kpi-icon"></i>
                    <div class="kpi-num">@Model.Assets.Count</div>
                    <div class="kpi-lbl">Assets on this floor</div>
                </div>
            </div>
        </div>
        <div class="det-card">
            <div class="det-card-header"><i class="bi bi-layers"></i>Floor Information</div>
            <div class="det-body">
                <div class="det-item">
                    <div class="det-label">Building</div>
                    <div class="det-value">
                        <a asp-controller="Buildings" asp-action="Details" asp-route-id="@Model.BuildingId"
                           style="color:#667eea;text-decoration:none">@Model.Building.Name</a>
                    </div>
                </div>
                <div class="det-item">
                    <div class="det-label">Level</div>
                    <div class="det-value">Floor @Model.Level</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Name</div>
                    <div class="det-value" style="@(Model.Name == null ? "color:#a0aec0;font-weight:400" : "")">@(Model.Name ?? "—")</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Assets</div>
                    <div class="det-value">@Model.Assets.Count</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Added On</div>
                    <div class="det-value" style="color:#718096;font-weight:400">@Model.CreatedAt.ToString("MMMM d, yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="det-card">
            <div class="det-card-header">
                <i class="bi bi-cpu"></i>Assets on this Floor
                <span style="margin-left:auto;background:#f0f4ff;color:#667eea;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700">@Model.Assets.Count</span>
            </div>
            @if (Model.Assets.Any())
            {
                <table class="ast-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>QR Code</th>
                            <th>Status</th>
                            <th>Criticality</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.Assets)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Assets" asp-action="Details" asp-route-id="@a.Id"
                                       style="font-size:12px;font-weight:700;color:#2d3748;text-decoration:none">@a.Name</a>
                                </td>
                                <td style="font-family:monospace;color:#a0aec0;font-size:11px">@a.QRCode</td>
                                <td>
                                    <span style="font-size:11px;font-weight:600;color:@StatusColor(a.Status)">
                                        @a.Status.Replace("_"," ")
                                    </span>
                                </td>
                                <td><span class="ast-pill" style="background:@CritGrad(a.Criticality)">@a.Criticality</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="text-align:center;padding:50px 20px">
                    <i class="bi bi-cpu" style="font-size:40px;color:#e2e8f0;display:block;margin-bottom:12px"></i>
                    <p style="font-size:13px;color:#a0aec0;margin:0">No assets assigned to this floor.</p>
                </div>
            }
        </div>
    </div>
</div>
