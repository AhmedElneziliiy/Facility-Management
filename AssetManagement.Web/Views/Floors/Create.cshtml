@using AssetManagement.Models.Entities
@model AssetManagement.Models.ViewModels.FloorFormViewModel
@{
    ViewData["Title"] = "Add Floor";
    var buildings = ViewBag.Buildings as IEnumerable<Building> ?? Enumerable.Empty<Building>();
}

@section Styles {
<link rel="stylesheet" href="~/css/views/floors-form.css" asp-append-version="true" />
}

<div class="form-hero">
    @if (Model.BuildingId != Guid.Empty)
    {
        <a asp-controller="Buildings" asp-action="Details" asp-route-id="@Model.BuildingId" class="hero-back">
            <i class="bi bi-arrow-left"></i>Back to @(Model.BuildingName)
        </a>
    }
    else
    {
        <a asp-action="Index" class="hero-back"><i class="bi bi-arrow-left"></i>Back to Floors</a>
    }
    <p class="hero-title"><i class="bi bi-layers me-2" style="opacity:.85"></i>Add New Floor</p>
    <p class="hero-sub">Define a floor level within a building</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="form-card">
            <div class="form-card-header"><i class="bi bi-layers"></i>Floor Details</div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="form-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4 rounded-3"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="field-label"><i class="bi bi-building me-1"></i>Building *</label>
                            <select asp-for="BuildingId" class="field-select">
                                @foreach (var b in buildings)
                                {
                                    if (b.Id == Model.BuildingId) { <option value="@b.Id" selected>@b.Name</option> }
                                    else { <option value="@b.Id">@b.Name</option> }
                                }
                            </select>
                            <span asp-validation-for="BuildingId" class="field-error"></span>
                        </div>
                        <div class="col-12">
                            <label class="field-label"><i class="bi bi-hash me-1"></i>Floor Level *</label>
                            <input asp-for="Level" type="number" class="field-input" placeholder="e.g. 1" />
                            <span asp-validation-for="Level" class="field-error"></span>
                            <div class="field-hint">Use 0 for Ground Floor, negative numbers for basements (e.g. -1).</div>
                        </div>
                        <div class="col-12">
                            <label class="field-label"><i class="bi bi-tag me-1"></i>Floor Name <span style="font-weight:400;text-transform:none;letter-spacing:0">(optional)</span></label>
                            <input asp-for="Name" class="field-input" placeholder="e.g. Lobby, Mechanical, Executive" />
                        </div>
                    </div>
                </div>
                <div class="form-actions">
                    <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i>Cancel</a>
                    <button type="submit" class="btn-save"><i class="bi bi-plus-lg"></i>Add Floor</button>
                </div>
            </form>
        </div>
    </div>
</div>
