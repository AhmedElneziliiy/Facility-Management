@model CreateVendorViewModel
@{
    ViewData["Title"] = "New Vendor";
}

@section Styles {
<link rel="stylesheet" href="~/css/views/vendors-form.css" asp-append-version="true" />
}

<div class="form-hero">
    <a asp-action="Index" class="hero-back"><i class="bi bi-arrow-left"></i>Back to Vendors</a>
    <p class="hero-title"><i class="bi bi-shop me-2" style="opacity:.85"></i>New Vendor</p>
    <p class="hero-sub">Add a new service provider or contractor</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card">
            <div class="form-card-header"><i class="bi bi-shop"></i>Vendor Information</div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="form-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4 rounded-3"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="field-label"><i class="bi bi-building me-1"></i>Company Name *</label>
                            <input asp-for="Name" class="field-input" placeholder="e.g. ACME Elevators" />
                            <span asp-validation-for="Name" class="field-error"></span>
                        </div>
                        <div class="col-12">
                            <label class="field-label"><i class="bi bi-person me-1"></i>Contact Person</label>
                            <input asp-for="ContactName" class="field-input" placeholder="e.g. John Smith" />
                        </div>
                        <div class="col-sm-6">
                            <label class="field-label"><i class="bi bi-telephone me-1"></i>Phone</label>
                            <input asp-for="ContactPhone" class="field-input" placeholder="e.g. +20123456789" />
                        </div>
                        <div class="col-sm-6">
                            <label class="field-label"><i class="bi bi-envelope me-1"></i>Email</label>
                            <input asp-for="ContactEmail" type="email" class="field-input" placeholder="e.g. contact@vendor.com" />
                            <span asp-validation-for="ContactEmail" class="field-error"></span>
                        </div>
                    </div>
                </div>
                <div class="form-actions">
                    <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i>Cancel</a>
                    <button type="submit" class="btn-save"><i class="bi bi-plus-lg"></i>Add Vendor</button>
                </div>
            </form>
        </div>
    </div>
</div>
