@using AssetManagement.Models.Entities
@model Vendor
@{
    ViewData["Title"] = Model.Name;
    var initials = string.Concat(Model.Name.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));
    string PriorityGrad(string p) => p.ToLower() switch {
        "critical" => "linear-gradient(135deg,#fa709a,#fee140)",
        "urgent"   => "linear-gradient(135deg,#f093fb,#f5576c)",
        "normal"   => "linear-gradient(135deg,#667eea,#764ba2)",
        "low"      => "linear-gradient(135deg,#11998e,#38ef7d)",
        _          => "linear-gradient(135deg,#a0aec0,#718096)"
    };
    string StatusGrad(string s) => s.ToLower() switch {
        "open"        => "linear-gradient(135deg,#667eea,#764ba2)",
        "in_progress" => "linear-gradient(135deg,#f39c12,#f5a623)",
        "closed"      => "linear-gradient(135deg,#11998e,#38ef7d)",
        _             => "linear-gradient(135deg,#a0aec0,#718096)"
    };
}

@section Styles {
<link rel="stylesheet" href="~/css/views/vendors-details.css" asp-append-version="true" />
}

<!-- HERO -->
<div class="det-hero">
    <a asp-action="Index" class="hero-back"><i class="bi bi-arrow-left"></i>Back to Vendors</a>
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div style="position:relative;z-index:1">
            <div class="d-flex align-items-center gap-3 mb-2">
                <div class="hero-avatar">@initials</div>
                <div>
                    <p class="hero-name mb-0">@Model.Name</p>
                    <p class="hero-sub mb-0">Service Provider · Added @Model.CreatedAt.ToString("MMM d, yyyy")</p>
                </div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2" style="position:relative;z-index:1">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="hbtn hbtn-edit">
                <i class="bi bi-pencil"></i>Edit
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mb-0"
                  onsubmit="return confirm('Delete vendor @Model.Name? This cannot be undone.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="hbtn hbtn-del"><i class="bi bi-trash"></i>Delete</button>
            </form>
        </div>
    </div>
</div>

<!-- BODY -->
<div class="row g-4">
    <div class="col-lg-4">
        <!-- KPI chips -->
        <div class="row g-3 mb-4">
            <div class="col-6">
                <div class="kpi-chip" style="background:linear-gradient(135deg,#667eea,#764ba2)">
                    <i class="bi bi-ticket-detailed kpi-icon"></i>
                    <div class="kpi-num">@Model.Tickets.Count</div>
                    <div class="kpi-lbl">Total Tickets</div>
                </div>
            </div>
            <div class="col-6">
                <div class="kpi-chip" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                    <i class="bi bi-check-circle kpi-icon"></i>
                    <div class="kpi-num">@Model.Tickets.Count(t => t.Status == "closed")</div>
                    <div class="kpi-lbl">Closed</div>
                </div>
            </div>
        </div>
        <!-- Info card -->
        <div class="det-card">
            <div class="det-card-header"><i class="bi bi-shop"></i>Vendor Information</div>
            <div class="det-body">
                <div class="det-item">
                    <div class="det-label">Company Name</div>
                    <div class="det-value">@Model.Name</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Contact Person</div>
                    <div class="det-value">@(Model.ContactName ?? "—")</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Phone</div>
                    <div class="det-value">
                        @if (!string.IsNullOrEmpty(Model.ContactPhone))
                        { <a href="tel:@Model.ContactPhone" style="color:#667eea;text-decoration:none">@Model.ContactPhone</a> }
                        else { <span style="color:#a0aec0">—</span> }
                    </div>
                </div>
                <div class="det-item">
                    <div class="det-label">Email</div>
                    <div class="det-value">
                        @if (!string.IsNullOrEmpty(Model.ContactEmail))
                        { <a href="mailto:@Model.ContactEmail" style="color:#667eea;text-decoration:none">@Model.ContactEmail</a> }
                        else { <span style="color:#a0aec0">—</span> }
                    </div>
                </div>
                <div class="det-item">
                    <div class="det-label">Added On</div>
                    <div class="det-value" style="color:#718096;font-weight:400">@Model.CreatedAt.ToString("MMMM d, yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="det-card">
            <div class="det-card-header">
                <i class="bi bi-ticket-detailed"></i>Assigned Tickets
                <span style="margin-left:auto;background:#f0f4ff;color:#667eea;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700">@Model.Tickets.Count</span>
            </div>
            @if (Model.Tickets.Any())
            {
                <div class="table-responsive">
                    <table class="tkt-table">
                        <thead>
                            <tr>
                                <th>Ticket #</th>
                                <th>Title</th>
                                <th>Priority</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Tickets)
                            {
                                <tr>
                                    <td style="font-family:monospace;color:#a0aec0;font-size:11px">@t.TicketNumber</td>
                                    <td>
                                        <a asp-controller="Tickets" asp-action="Details" asp-route-id="@t.Id"
                                           style="font-size:12px;font-weight:700;color:#2d3748;text-decoration:none">@t.Title</a>
                                    </td>
                                    <td><span class="tkt-pill" style="background:@PriorityGrad(t.Priority)">@t.Priority</span></td>
                                    <td><span class="tkt-pill" style="background:@StatusGrad(t.Status)">@t.Status.Replace("_"," ")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="text-align:center;padding:50px 20px">
                    <i class="bi bi-ticket" style="font-size:40px;color:#e2e8f0;display:block;margin-bottom:12px"></i>
                    <p style="font-size:13px;color:#a0aec0;margin:0">No tickets assigned to this vendor yet.</p>
                </div>
            }
        </div>
    </div>
</div>
