@using AssetManagement.Models.Entities
@model Building
@{
    ViewData["Title"] = Model.Name;
}

@section Styles {
<link rel="stylesheet" href="~/css/views/buildings-details.css" asp-append-version="true" />
}

<!-- HERO -->
<div class="det-hero">
    <a asp-action="Index" class="hero-back"><i class="bi bi-arrow-left"></i>Back to Buildings</a>
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div style="position:relative;z-index:1">
            <p class="hero-name"><i class="bi bi-building me-2" style="opacity:.7"></i>@Model.Name</p>
            <p class="hero-sub"><i class="bi bi-geo-alt me-1"></i>@(Model.Address ?? "No address provided")</p>
            <div class="hero-chips">
                <span class="hero-chip"><i class="bi bi-layers" style="font-size:11px"></i>@Model.Floors.Count Floors</span>
                <span class="hero-chip"><i class="bi bi-cpu" style="font-size:11px"></i>@Model.Assets.Count Assets</span>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2" style="position:relative;z-index:1">
            <a asp-controller="Floors" asp-action="Create" asp-route-buildingId="@Model.Id" class="hbtn hbtn-floor">
                <i class="bi bi-layers"></i>Add Floor
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="hbtn hbtn-edit">
                <i class="bi bi-pencil"></i>Edit
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mb-0"
                  onsubmit="return confirm('Delete building @Model.Name? This cannot be undone.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="hbtn hbtn-del"><i class="bi bi-trash"></i>Delete</button>
            </form>
        </div>
    </div>
</div>

<!-- BODY -->
<div class="row g-4">
    <!-- LEFT: Info + KPIs -->
    <div class="col-lg-4">
        <div class="row g-3 mb-3">
            <div class="col-6">
                <div class="kpi-chip" style="background:linear-gradient(135deg,#4facfe,#00f2fe)">
                    <i class="bi bi-layers kpi-icon"></i>
                    <div class="kpi-num">@Model.Floors.Count</div>
                    <div class="kpi-lbl">Floors</div>
                </div>
            </div>
            <div class="col-6">
                <div class="kpi-chip" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                    <i class="bi bi-cpu kpi-icon"></i>
                    <div class="kpi-num">@Model.Assets.Count</div>
                    <div class="kpi-lbl">Assets</div>
                </div>
            </div>
        </div>
        <div class="det-card">
            <div class="det-card-header"><i class="bi bi-building"></i>Building Information</div>
            <div class="det-body">
                <div class="det-item">
                    <div class="det-label">Name</div>
                    <div class="det-value">@Model.Name</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Address</div>
                    <div class="det-value" style="font-size:13px;font-weight:400;color:#718096">@(Model.Address ?? "—")</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Total Floors</div>
                    <div class="det-value">@Model.Floors.Count</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Total Assets</div>
                    <div class="det-value">@Model.Assets.Count</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Added On</div>
                    <div class="det-value" style="color:#718096;font-weight:400">@Model.CreatedAt.ToString("MMMM d, yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Floors list -->
    <div class="col-lg-8">
        <div class="det-card">
            <div class="det-card-header">
                <i class="bi bi-layers"></i>Floors
                <span style="margin-left:auto;background:#f0f4ff;color:#667eea;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700">@Model.Floors.Count</span>
                <a asp-controller="Floors" asp-action="Create" asp-route-buildingId="@Model.Id"
                   style="display:inline-flex;align-items:center;gap:4px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:7px;padding:5px 12px;font-size:12px;font-weight:700;text-decoration:none;margin-left:8px">
                    <i class="bi bi-plus-lg"></i>Add Floor
                </a>
            </div>
            @if (Model.Floors.Any())
            {
                @foreach (var f in Model.Floors.OrderBy(f => f.Level))
                {
                    <div class="floor-row">
                        <div class="d-flex align-items-center">
                            <span class="floor-badge"><i class="bi bi-layers" style="font-size:10px"></i>Floor @f.Level</span>
                            @if (!string.IsNullOrEmpty(f.Name))
                            {
                                <span class="floor-name">@f.Name</span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span class="floor-assets">@Model.Assets.Count(a => a.FloorId == f.Id) asset(s)</span>
                            <div class="d-flex gap-1">
                                <a asp-controller="Floors" asp-action="Edit" asp-route-id="@f.Id" class="act-btn act-edit" title="Edit"><i class="bi bi-pencil"></i></a>
                                <form asp-controller="Floors" asp-action="Delete" asp-route-id="@f.Id" method="post" class="mb-0"
                                      onsubmit="return confirm('Delete Floor @f.Level?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="act-btn act-del" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center;padding:50px 20px">
                    <i class="bi bi-layers" style="font-size:40px;color:#e2e8f0;display:block;margin-bottom:12px"></i>
                    <p style="font-size:13px;color:#a0aec0;margin-bottom:16px">No floors defined yet.</p>
                    <a asp-controller="Floors" asp-action="Create" asp-route-buildingId="@Model.Id"
                       style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:9px;padding:9px 20px;font-size:13px;font-weight:700;text-decoration:none">
                        <i class="bi bi-plus-lg"></i>Add First Floor
                    </a>
                </div>
            }
        </div>
    </div>
</div>
