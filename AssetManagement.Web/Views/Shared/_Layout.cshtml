<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Asset Management</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">
            <i class="bi bi-building-gear"></i>
        </div>
        <span class="sidebar-title">FacilityMS</span>
        <button class="sidebar-toggle" id="sidebarToggle" title="Toggle Sidebar">
            <i class="bi bi-list"></i>
        </button>
    </div>

    <div class="sidebar-user">
        <div class="user-avatar">
            <i class="bi bi-person-fill"></i>
        </div>
        <div class="sidebar-user-info">
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-role">
                @if (User.IsInRole("admin"))       { <span>Admin</span> }
                else if (User.IsInRole("manager")) { <span>Manager</span> }
                else if (User.IsInRole("coordinator")) { <span>Coordinator</span> }
                else                               { <span>Facilities</span> }
            </div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <ul class="nav-list">
            <li class="nav-section-item">
                <span class="nav-section-label">Main</span>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Dashboard" asp-action="Index" data-tooltip="Dashboard">
                    <i class="bi bi-speedometer2"></i>
                    <span class="nav-text">Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Tickets" asp-action="Index" data-tooltip="Tickets">
                    <i class="bi bi-ticket-detailed"></i>
                    <span class="nav-text">Tickets</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Assets" asp-action="Index" data-tooltip="Assets">
                    <i class="bi bi-cpu"></i>
                    <span class="nav-text">Assets</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Reports" asp-action="Index" data-tooltip="Reports">
                    <i class="bi bi-bar-chart-line"></i>
                    <span class="nav-text">Reports</span>
                </a>
            </li>

            <li class="nav-section-item">
                <span class="nav-section-label">Manage</span>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Users" asp-action="Index" data-tooltip="Users">
                    <i class="bi bi-people"></i>
                    <span class="nav-text">Users</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Vendors" asp-action="Index" data-tooltip="Vendors">
                    <i class="bi bi-building"></i>
                    <span class="nav-text">Vendors</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Buildings" asp-action="Index" data-tooltip="Buildings">
                    <i class="bi bi-buildings"></i>
                    <span class="nav-text">Buildings</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-controller="Floors" asp-action="Index" data-tooltip="Floors">
                    <i class="bi bi-layers"></i>
                    <span class="nav-text">Floors</span>
                </a>
            </li>
        </ul>
    </nav>

    <div class="sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-logout" data-tooltip="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span class="nav-text">Logout</span>
            </button>
        </form>
    </div>
</aside>

<!-- Overlay (mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Mobile menu button -->
<button class="mobile-menu-btn" id="mobileMenuBtn" title="Open Menu">
    <i class="bi bi-list"></i>
</button>

<!-- Main content -->
<main class="main-content">
    <div class="container-fluid py-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/app.js" asp-append-version="true"></script>
<script src="~/js/sidebar.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
