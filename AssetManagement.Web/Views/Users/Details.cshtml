@using AssetManagement.Infrastructure.Identity
@model ApplicationUser
@{
    ViewData["Title"] = Model.FullName;
    var ticketsCreated  = (int)(ViewBag.TicketsCreated  ?? 0);
    var ticketsAssigned = (int)(ViewBag.TicketsAssigned ?? 0);

    string RoleGrad(string r) => r.ToLower() switch {
        "manager"     => "linear-gradient(135deg,#667eea,#764ba2)",
        "coordinator" => "linear-gradient(135deg,#4facfe,#00f2fe)",
        "facilities"  => "linear-gradient(135deg,#11998e,#38ef7d)",
        _             => "linear-gradient(135deg,#a0aec0,#718096)"
    };
    string RoleIcon(string r) => r.ToLower() switch {
        "manager"     => "bi-person-badge-fill",
        "coordinator" => "bi-person-gear",
        "facilities"  => "bi-wrench-adjustable",
        _             => "bi-person"
    };
    var initials = string.Concat(Model.FullName.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));
}

@section Styles {
<link rel="stylesheet" href="~/css/views/users-details.css" asp-append-version="true" />
}

<!-- ════════════ HERO ════════════ -->
<div class="detail-hero">
    <a asp-action="Index" class="hero-back"><i class="bi bi-arrow-left"></i>Back to Users</a>
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div style="position:relative;z-index:1">
            <div class="d-flex align-items-center gap-3 mb-2">
                <div class="hero-avatar" style="background:@RoleGrad(Model.Role)">@initials</div>
                <div>
                    <p class="hero-name mb-0">@Model.FullName</p>
                    <p class="hero-sub mb-0">@@@Model.UserName · @Model.Email</p>
                </div>
            </div>
            <div class="hero-chips">
                <span class="hero-chip" style="background:@RoleGrad(Model.Role)">
                    <i class="bi @RoleIcon(Model.Role)" style="font-size:11px"></i>@Model.Role
                </span>
                @if (Model.IsActive)
                {
                    <span class="hero-chip" style="background:rgba(17,153,142,.6)">
                        <i class="bi bi-check-circle-fill" style="font-size:11px"></i>Active
                    </span>
                }
                else
                {
                    <span class="hero-chip" style="background:rgba(245,87,108,.5)">
                        <i class="bi bi-slash-circle" style="font-size:11px"></i>Inactive
                    </span>
                }
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2" style="position:relative;z-index:1">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="hbtn hbtn-edit">
                <i class="bi bi-pencil"></i>Edit
            </a>
            <form asp-action="ToggleActive" asp-route-id="@Model.Id" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="hbtn @(Model.IsActive ? "hbtn-warn" : "hbtn-success")">
                    <i class="bi @(Model.IsActive ? "bi-person-slash" : "bi-person-check")"></i>
                    @(Model.IsActive ? "Deactivate" : "Activate")
                </button>
            </form>
            <button class="hbtn hbtn-key" data-bs-toggle="modal" data-bs-target="#resetPwdModal"
                    data-user-id="@Model.Id" data-user-name="@Model.UserName">
                <i class="bi bi-key"></i>Reset Password
            </button>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mb-0"
                  onsubmit="return confirm('Delete user @Model.UserName? This cannot be undone.')">
                @Html.AntiForgeryToken()
                <button type="submit" class="hbtn hbtn-del"><i class="bi bi-trash"></i>Delete</button>
            </form>
        </div>
    </div>
</div>

<!-- ════════════ BODY ════════════ -->
<div class="row g-4">

    <div class="col-lg-5">
        <div class="det-card">
            <div class="det-card-header"><i class="bi bi-person-circle"></i>User Information</div>
            <div class="det-body">
                <div class="det-item">
                    <div class="det-label">Full Name</div>
                    <div class="det-value">@Model.FullName</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Username</div>
                    <div class="det-value" style="font-family:monospace">@@@Model.UserName</div>
                </div>
                <div class="det-item">
                    <div class="det-label">Email</div>
                    <div class="det-value"><a href="mailto:@Model.Email" style="color:#667eea;text-decoration:none">@Model.Email</a></div>
                </div>
                <div class="det-item">
                    <div class="det-label">Role</div>
                    <div class="det-value">
                        <span style="display:inline-flex;align-items:center;gap:5px;border-radius:20px;padding:4px 12px;font-size:12px;font-weight:700;color:#fff;background:@RoleGrad(Model.Role)">
                            <i class="bi @RoleIcon(Model.Role)" style="font-size:10px"></i>@Model.Role
                        </span>
                    </div>
                </div>
                <div class="det-item">
                    <div class="det-label">Status</div>
                    <div class="det-value">
                        @if (Model.IsActive)
                        { <span style="color:#11998e;font-weight:700"><i class="bi bi-check-circle-fill me-1"></i>Active</span> }
                        else
                        { <span style="color:#fa709a;font-weight:700"><i class="bi bi-slash-circle me-1"></i>Inactive</span> }
                    </div>
                </div>
                <div class="det-item">
                    <div class="det-label">Member Since</div>
                    <div class="det-value" style="color:#718096;font-weight:400">@Model.CreatedAt.ToString("MMMM d, yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="kpi-row">
            <div class="kpi-chip" style="background:linear-gradient(135deg,#667eea,#764ba2)">
                <i class="bi bi-ticket-detailed kpi-icon"></i>
                <div class="kpi-num">@ticketsCreated</div>
                <div class="kpi-label">Tickets Created</div>
            </div>
            <div class="kpi-chip" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                <i class="bi bi-person-check kpi-icon"></i>
                <div class="kpi-num">@ticketsAssigned</div>
                <div class="kpi-label">Tickets Assigned</div>
            </div>
        </div>
        <div class="det-card">
            <div class="det-card-header"><i class="bi bi-bar-chart-fill"></i>Reports</div>
            <div class="det-body text-center" style="padding:40px 20px">
                <i class="bi bi-graph-up" style="font-size:40px;color:#e2e8f0;display:block;margin-bottom:12px"></i>
                <p style="font-size:13px;color:#a0aec0;margin-bottom:16px">View full activity reports for this user</p>
                <a asp-controller="Reports" asp-action="Index"
                   style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:9px;padding:9px 20px;font-size:13px;font-weight:600;text-decoration:none">
                    <i class="bi bi-bar-chart"></i>View Reports
                </a>
            </div>
        </div>
    </div>

</div>

<!-- ════════════ RESET PASSWORD MODAL ════════════ -->
<div class="modal fade" id="resetPwdModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <form method="post" id="resetPwdForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <div>
                        <h6 class="modal-title mb-0"><i class="bi bi-key me-2"></i>Reset Password</h6>
                        <small class="opacity-75">@@@Model.UserName</small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="modal-label">New Password</label>
                    <input type="password" name="newPassword" class="form-control" placeholder="Min. 6 characters" required minlength="6" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border:none;border-radius:8px;padding:8px 18px;font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:6px">
                        <i class="bi bi-check-lg"></i>Reset
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/views/users-details.js" asp-append-version="true"></script>
}
